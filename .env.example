# STOFabric environment template
# Copy this file to ".env" and fill real values.
# Do not commit ".env" with real secrets.

# -------------------------------------------------------------------
# Required for full pipeline (content transformer stage)
# -------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_ENV=OPENROUTER_API_KEY
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=90
OPENROUTER_RETRIES=4
OPENROUTER_RETRY_BACKOFF_BASE_SECONDS=2.0
OPENROUTER_MAX_INPUT_CHARS_PER_REQUEST=2200
OPENROUTER_CHUNK_OVERLAP_CHARS=180
OPENROUTER_REWRITE_STRATEGY=single_pass
OPENROUTER_FAIL_ON_REWRITE_ERROR=false
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_AFTER_TIMEOUTS=2

# Legacy (deprecated): kept for migration fallback only.
NVIDIA_API_KEY=
NVIDIA_API_KEY_ENV=NVIDIA_API_KEY
NVIDIA_MODEL=
NVIDIA_API_URL=
NVIDIA_TIMEOUT_SECONDS=
NVIDIA_RETRIES=
NVIDIA_RETRY_BACKOFF_BASE_SECONDS=
NVIDIA_MAX_INPUT_CHARS_PER_REQUEST=
NVIDIA_CHUNK_OVERLAP_CHARS=
NVIDIA_REWRITE_STRATEGY=
NVIDIA_FAIL_ON_REWRITE_ERROR=
NVIDIA_FALLBACK_MODEL=
NVIDIA_FALLBACK_AFTER_TIMEOUTS=

# Optional: choose model key used by controller/quality_controller CLI.
# Supported: 8b (Gemini Flash), 70b (Gemini Pro), 405b (alias to Gemini Pro)
STO_MODEL_KEY=70b

# -------------------------------------------------------------------
# Common pipeline paths (used as convenient defaults in scripts/tasks)
# -------------------------------------------------------------------
STO_INPUT_DOCX=C:\Users\User\Desktop\Рабочие документы\СТО\Черновик Регламент заявки техники.docx
STO_OUTPUT_DOCX=_tmp_extract\final_sto.docx
STO_RULES_PATH=mapping-rules.yaml
STO_SCHEMA_PATH=sto-model.schema.json
STO_CHECKLIST_PATH=sto-validation-checklist.yaml

# Pipeline mode: full | up-to-mapper | up-to-transformer
STO_MODE=full

# Behavior flags (true/false)
STO_SAVE_INTERMEDIATE=true
STO_DRY_RUN=false
STO_VERBOSE=true

# -------------------------------------------------------------------
# Quality controller defaults
# -------------------------------------------------------------------
STO_QUALITY_OUTPUT_DIR=_tmp_extract\quality_report
STO_QUALITY_DRAFTS_DIR=C:\Users\User\Desktop\Рабочие документы\СТО

# Optional single-file test target for quality_controller.py --test
STO_QUALITY_TEST_DOCX=

